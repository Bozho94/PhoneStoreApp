{
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.angular": true,
    "**/node_modules": true,
    "**/dist": true
  },
  "git.repositoryScanIgnoredFolders": [
    "node_modules",
    "dist",
    ".angular",
    "bin",
    "obj",
    "temp-build"
  ],
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
